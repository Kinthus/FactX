<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECECFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyze Image News"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#173B91"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload an image to verify whether it is fake or real."
            android:textSize="16sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="25dp"/>

        <!-- Image Preview -->

        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="250dp"
            android:layout_height="250dp"
            android:layout_gravity="center"
            android:background="#DDDDDD"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerInside"/>

        <!-- Select Image -->

        <Button
            android:id="@+id/btnGallery"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:text="Choose from Gallery"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#173B91"
            android:textColor="#FFFFFF"/>

        <!-- Camera -->

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:text="Open Camera"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"/>

        <!-- Analyze -->

        <Button
            android:id="@+id/btnAnalyzeImage"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:text="Analyze Image"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

        <!-- Clear -->

        <Button
            android:id="@+id/btnClearImage"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:text="Clear"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#BDBDBD"
            android:textColor="#000000"/>

    </LinearLayout>

</ScrollView>