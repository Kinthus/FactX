<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECECFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyze Multimodal News"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#173B91"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"/>

        <!-- Description -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload both news text and image for verification."
            android:textSize="16sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="25dp"/>

        <!-- News Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="News Title"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Enter News Title"
            android:padding="15dp"
            android:layout_marginTop="8dp"/>

        <!-- News Content -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="News Content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/etNews"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:gravity="top|start"
            android:hint="Paste the complete news article..."
            android:padding="15dp"
            android:inputType="textMultiLine"
            android:minLines="6"/>

        <!-- Image Preview -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="News Image"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="20dp"/>

        <ImageView
            android:id="@+id/imgPreview"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:background="#DDDDDD"
            android:src="@android:drawable/ic_menu_gallery"
            android:scaleType="centerInside"/>

        <!-- Gallery -->

        <Button
            android:id="@+id/btnGallery"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:text="Choose From Gallery"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#173B91"
            android:textColor="#FFFFFF"/>

        <!-- Camera -->

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:text="Open Camera"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#1976D2"
            android:textColor="#FFFFFF"/>

        <!-- Analyze -->

        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="20dp"
            android:text="Analyze Multimodal News"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

        <!-- Clear -->

        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:text="Clear"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#BDBDBD"
            android:textColor="#000000"/>

    </LinearLayout>

</ScrollView>