<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECECFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Result Icon -->

        <ImageView
            android:id="@+id/imgResult"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="20dp"
            android:rotationX="21"
            android:src="@android:drawable/ic_delete" />

        <!-- Title -->

        <TextView
            android:id="@+id/txtResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="FAKE NEWS DETECTED"
            android:textColor="#D32F2F"
            android:textSize="30sp"
            android:textStyle="bold" />

        <!-- Confidence -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="Confidence Score"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/progressConfidence"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginTop="10dp"
            android:max="100"
            android:progress="96" />

        <TextView
            android:id="@+id/txtConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="96%"
            android:textColor="#173B91"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- AI Explanation -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:text="AI Explanation"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            android:padding="15dp"
            android:text="• Manipulated image detected.\n\n• Suspicious headline.\n\n• Text and image do not match.\n\n• AI classified this content as Fake News."
            android:textSize="16sp" />

        <!-- Analyze Again -->

        <Button
            android:id="@+id/btnAgain"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:backgroundTint="#173B91"
            android:text="Analyze Again"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Report -->

        <Button
            android:id="@+id/btnReport"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:backgroundTint="#D32F2F"
            android:text="Report Problem"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Home -->

        <Button
            android:id="@+id/btnHome"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:backgroundTint="#4CAF50"
            android:text="Back to Home"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>