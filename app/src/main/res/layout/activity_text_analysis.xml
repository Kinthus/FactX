<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECECFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyze Text News"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#173B91"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"/>

        <!-- Description -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paste or type the news article below."
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="25dp"/>

        <!-- News Heading -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="News Title"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Enter News Title"
            android:layout_marginTop="8dp"
            android:padding="15dp"
            android:background="@android:drawable/edit_text"/>

        <!-- News Content -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="News Content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/etNews"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:hint="Paste the complete news article here..."
            android:gravity="top|start"
            android:padding="15dp"
            android:background="@android:drawable/edit_text"
            android:inputType="textMultiLine"
            android:minLines="8"/>

        <!-- Analyze Button -->

        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:text="Analyze News"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#173B91"
            android:textColor="#FFFFFF"/>

        <!-- Clear Button -->

        <Button
            android:id="@+id/btnClear"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="15dp"
            android:text="Clear"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="#BDBDBD"
            android:textColor="#000000"/>

    </LinearLayout>

</ScrollView>